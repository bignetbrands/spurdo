# ============================================================
# spurdo bot — environment variables
# ============================================================
# Copy this to .env.local and fill in the values.
# Never commit .env.local. See DEPLOY.md for what each value is.
# ============================================================

# Project identity
PROJECT=spurdo

# Auth secrets — generate two random 32+ char strings
ADMIN_SECRET=
CRON_SECRET=

# Upstash Redis (Vercel auto-injects these when you connect Upstash)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# LLM keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Image generation (Fal.ai — primary, FLUX LoRA-capable)
FAL_KEY=
# After M2.5 LoRA training, set this to the trained LoRA URL:
SPURDO_LORA_URL=
# Image provider: "fal" (default) or "openai" (fallback)
IMAGE_PROVIDER=fal

# === RESILIENCE OVERRIDES (optional) ===
# Set to "1" to bypass daily image + token budget caps. Use only in emergencies.
BUDGET_OVERRIDE=
# Generate endpoint rate limit (per minute). Default: 10
GENERATE_RATE_PER_MINUTE=

# === DRY RUN (M3) ===
# Set to "1" to skip the actual X API call. The orchestrator runs end-to-end
# (text gen, image gen, KV record, log) but doesn't post anything.
# Use this to test the cron pipeline before adding X API credentials.
DRY_RUN=

# === MEME BANK (M4) — memedepot.com scraper ===
# Slug for memedepot.com/d/${slug}. Defaults to projectId.
MEMEDEPOT_SLUG=
# CDN width param. Default: 1080. Lower = faster fetches but lower quality.
MEMEDEPOT_CDN_WIDTH=
# Fallback image IDs (comma-separated UUIDs). Used if scrape fails.
# To populate: visit memedepot.com/d/spurdo, view-source, search /imagedelivery/
MEMEDEPOT_FALLBACK_IDS=
# Cloudflare imagedelivery account ID. Auto-discovered on first scrape — only set
# this if you want fallback URLs to work BEFORE the first successful scrape.
MEMEDEPOT_CF_ACCOUNT_ID=
# UUIDs to exclude from the scraped manifest (comma-separated). Used to skip
# the depot banner, off-canon variants, etc. Hardcoded defaults already exclude
# known bad IDs; this env appends to them.
MEMEDEPOT_EXCLUDE_IDS=

# === IMAGE GENERATION STACK (M5) ===
# The active gen stack is declared per-project in
# config/${PROJECT}/image-prompts.json → genStack. The env vars below
# are optional overrides for stack-specific behavior.

# SDXL base model identifier (huggingface ID or fal-supported alias).
# Default: stabilityai/stable-diffusion-xl-base-1.0
# Recommended alternatives for stylized work:
#   "ponydiffusion/pony-diffusion-v6"  — best for varied illustration styles
#   "illustrious-xl/illustrious-xl"    — best for clean anime/illustration
SDXL_BASE_MODEL=

# X API (Basic tier)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=
